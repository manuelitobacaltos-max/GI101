                                            <th style="width:15%">Category</th>
                                            <th style="width:12%">Quantity</th>
                                            <th style="width:10%">UoM</th>
                                            <th style="width:23%">Purpose</th>
                                            <th style="width:5%" class="no-print"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsBody">
                                        <!-- rows injected here -->
                                    </tbody>
                                </table>
                            </div>
                            <button type="button" class="btn btn-sm btn-add-row no-print" id="btnAddRow">
                                <i class="bi bi-plus-circle"></i> Add Another Item
                            </button>
                        </div>

                        <!-- APPROVAL -->
                        <div class="mb-4">
                            <label class="section-title"><i class="bi bi-shield-check"></i> Approval Routing</label>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small mb-1">Approving Manager</label>
                                    <select id="approverList" class="form-select" required>
                                        <option value="" disabled selected>-- Select Manager --</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small mb-1">Cc / Notify (optional)</label>
                                    <input type="text" id="ccEmail" class="form-control" placeholder="e.g. warehouse@vienovo.ph; finance@vienovo.ph">
                                </div>
                            </div>
                            <div class="alert alert-info mt-2 mb-0 py-2 small" id="routingHint" style="display:none;">
                                <i class="bi bi-info-circle"></i> <span id="routingText"></span>
                            </div>
                        </div>

                        <!-- JUSTIFICATION -->
