                            <label class="section-title"><i class="bi bi-chat-left-text"></i> Justification</label>
                            <textarea id="explanation" class="form-control" rows="3"
                                placeholder="State the business reason / project / SAP reference for this issuance..." required></textarea>
                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex gap-2 flex-wrap no-print">
                            <button type="button" class="btn btn-outline-secondary" id="btnPreview">
                                <i class="bi bi-eye"></i> Preview Email
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="btnSaveDraft">
                                <i class="bi bi-save"></i> Save Draft
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                                <i class="bi bi-printer"></i> Print
                            </button>
                            <button type="button" class="btn btn-outline-danger" id="btnClear">
                                <i class="bi bi-trash"></i> Clear
                            </button>
                            <button type="submit" class="btn btn-primary flex-grow-1" id="btnSubmit">
                                <i class="bi bi-send-check"></i> Send Request for Approval
                            </button>
                        </div>

                        <div id="statusMsg" class="mt-3" style="display:none;"></div>
                    </form>

                    <div class="footer-note">
                        <i class="bi bi-lock"></i> All submissions are logged. Frontend prototype &mdash; pending SAP B1 / OITM integration.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- PREVIEW MODAL -->
