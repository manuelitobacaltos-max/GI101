        <td>
            <select class="form-select form-select-sm item-name" required>
                <option value="" disabled selected>-- Select Material --</option>
                ${Object.entries(MATERIALS).map(([cat, items]) =>
                    `<optgroup label="${cat}">${items.map(i => `<option value="${i}" data-cat="${cat}">${i}</option>`).join('')}</optgroup>`
                ).join('')}
                <option value="__custom__">+ Type custom item...</option>
            </select>
            <input type="text" class="form-control form-control-sm mt-1 item-custom" placeholder="Custom item name" style="display:none;">
        </td>
        <td><input type="text" class="form-control form-control-sm item-cat" readonly></td>
        <td><input type="number" class="form-control form-control-sm item-qty" min="1" value="1" required></td>
        <td>
            <select class="form-select form-select-sm item-uom">
                ${UOM_LIST.map(u => `<option value="${u}">${u}</option>`).join('')}
            </select>
        </td>
        <td><input type="text" class="form-control form-control-sm item-purpose" placeholder="e.g. Line 2 repair"></td>
        <td class="no-print text-center">
            <button type="button" class="btn btn-sm btn-outline-danger btn-del-row"><i class="bi bi-x"></i></button>
        </td>
    `;
    tbody.appendChild(tr);

    // wiring
    const sel = tr.querySelector('.item-name');
    const customInput = tr.querySelector('.item-custom');
    const catInput = tr.querySelector('.item-cat');
    sel.addEventListener('change', () => {
        if (sel.value === '__custom__') {
            customInput.style.display = 'block';
            catInput.value = 'Custom';
        } else {
            customInput.style.display = 'none';
            const opt = sel.options[sel.selectedIndex];
            catInput.value = opt.dataset.cat || '';
        }
    });
    tr.querySelector('.btn-del-row').addEventListener('click', () => {
        if (document.querySelectorAll('#itemsBody tr').length > 1) tr.remove();
    });
}
addRow();
document.getElementById('btnAddRow').addEventListener('click', addRow);

// =========================================================
// COLLECT FORM DATA
// =========================================================
function collectData() {
    const e = EMPLOYEES[empSel.value] || ["","","","",""];
    const m = MANAGERS[mgrSel.value] || {name:"",email:"",role:""};
    const items = Array.from(document.querySelectorAll('#itemsBody tr')).map(tr => {
        let name = tr.querySelector('.item-name').value;
        if (name === '__custom__') name = tr.querySelector('.item-custom').value || '(unnamed)';
        return {
            name,
            category: tr.querySelector('.item-cat').value,
            qty: tr.querySelector('.item-qty').value,
            uom: tr.querySelector('.item-uom').value,
            purpose: tr.querySelector('.item-purpose').value
        };
    });
    return {
        ref: document.getElementById('refNumber').innerText,
        date_submitted: new Date().toLocaleString('en-PH'),
        date_needed: document.getElementById('dateNeeded').value,
        employee_name: `${e[1]} ${e[0]}`,
        employee_email: document.getElementById('empEmail').value,
        department: e[2], location: e[3], position: e[4],
        approver_name: m.name, approver_email: m.email, approver_role: m.role,
        cc: document.getElementById('ccEmail').value,
        items,
        justification: document.getElementById('explanation').value
    };
}

function buildEmailBody(d) {
    const itemsTxt = d.items.map((it,i) =>
        `  ${i+1}. ${it.name}  —  ${it.qty} ${it.uom}  [${it.category||'-'}]  ${it.purpose?'(' + it.purpose + ')':''}`
    ).join('\n');
    return `Hi ${d.approver_name.split(' ')[0]},

A new Goods Issuance request requires your approval.

------------------------------------------------------------
  Reference No.   : ${d.ref}
  Date Submitted  : ${d.date_submitted}
  Date Needed     : ${d.date_needed}
------------------------------------------------------------
  Requestor       : ${d.employee_name}
  Position        : ${d.position}
  Department      : ${d.department}
  Plant/Location  : ${d.location}
  Email           : ${d.employee_email}
------------------------------------------------------------
  Items Requested:
${itemsTxt}
------------------------------------------------------------
  Justification:
  ${d.justification}
------------------------------------------------------------

Please review and APPROVE / DECLINE this request in the Vienovo Goods Issuance portal.

Thank you,
Vienovo Goods Issuance System (automated)`;
}

// =========================================================
// PREVIEW
// =========================================================
document.getElementById('btnPreview').addEventListener('click', () => {
    const d = collectData();
    document.getElementById('pv-to').innerText = `${d.approver_name} <${d.approver_email}>`;
    document.getElementById('pv-cc').innerText = [d.employee_email, d.cc].filter(Boolean).join('; ') || '(none)';
    document.getElementById('pv-subj').innerText = `[${d.ref}] Goods Issuance Request - ${d.employee_name}`;
    document.getElementById('pv-body').innerText = buildEmailBody(d);
    new bootstrap.Modal(document.getElementById('preview-modal')).show();
});

// =========================================================
// DRAFT SAVE / LOAD (localStorage)
// =========================================================
const DRAFT_KEY = 'vno_gis_draft';
function showDraftIndicator() {
    const ind = document.getElementById('draftIndicator');
    ind.style.display = 'block';
    setTimeout(()=>ind.style.display='none', 1800);
}
document.getElementById('btnSaveDraft').addEventListener('click', () => {
    try {
        localStorage.setItem(DRAFT_KEY, JSON.stringify(collectData()));
        showDraftIndicator();
    } catch(e){ alert('Draft save failed: ' + e.message); }
});

// =========================================================
// CLEAR
// =========================================================
document.getElementById('btnClear').addEventListener('click', () => {
    if (!confirm('Clear all fields?')) return;
    document.getElementById('gisForm').reset();
    document.getElementById('itemsBody').innerHTML = '';
    addRow();
    document.getElementById('refNumber').innerText = genRefNumber();
    document.getElementById('routingHint').style.display = 'none';
});

// =========================================================
// SUBMIT (simulated email send)
// =========================================================
document.getElementById('gisForm').addEventListener('submit', e => {
    e.preventDefault();
    const btn = document.getElementById('btnSubmit');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sending...';

    const d = collectData();
    console.log('GIS Payload:', d);
    console.log('Email Body:\n' + buildEmailBody(d));

    // === When EmailJS is configured, uncomment: ===
    // emailjs.send('SERVICE_ID', 'TEMPLATE_ID', {
    //     to_email: d.approver_email,
    //     cc_email: d.employee_email,
    //     subject: `[${d.ref}] Goods Issuance Request - ${d.employee_name}`,
    //     message: buildEmailBody(d)
    // }).then(...);

    setTimeout(() => {
        // advance workflow visual
        document.getElementById('wf-1').classList.remove('active');
        document.getElementById('wf-1').classList.add('done');
        document.getElementById('wf-2').classList.add('active');

        const s = document.getElementById('statusMsg');
        s.style.display = 'block';
        s.innerHTML = `
            <div class="alert alert-success">
                <h6 class="mb-1"><i class="bi bi-check-circle"></i> Request submitted successfully!</h6>
                <p class="mb-1 small">Reference <strong>${d.ref}</strong> has been routed to <strong>${d.approver_name}</strong> (${d.approver_email}) for approval.</p>
                <p class="mb-0 small">Cc: ${d.employee_email}${d.cc?'; ' + d.cc:''}</p>
            </div>`;
        btn.innerHTML = '<i class="bi bi-check2"></i> Sent — Submit Another';
        btn.disabled = false;
    }, 1500);
});
</script>
</body>
