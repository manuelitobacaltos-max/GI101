    opt.value = i;
    opt.text = `${m.name} — ${m.role}`;
    mgrSel.appendChild(opt);
});

// =========================================================
// EMPLOYEE SELECT -> auto-fill + auto-route
// =========================================================
empSel.addEventListener('change', () => {
    const e = EMPLOYEES[empSel.value];
    if (!e) return;
    document.getElementById('empEmail').value = slugEmail(e[0], e[1]);
    document.getElementById('empDept').value = e[2];
    document.getElementById('empLoc').value = e[3];

    const mgr = findManager(e[2]);
    if (mgr) {
        const idx = MANAGERS.indexOf(mgr);
        mgrSel.value = idx;
        const hint = document.getElementById('routingHint');
        hint.style.display = 'block';
        document.getElementById('routingText').innerText =
            `Auto-routed to ${mgr.name} (${mgr.role}) based on ${e[2]} department.`;
    }
});

