// =========================================================
// HELPERS
// =========================================================
function slugEmail(last, first) {
    const clean = s => s.toLowerCase().replace(/[^a-z]/g,'');
    return `${clean(first)}.${clean(last)}@vienovo.ph`;
}
function findManager(dept) {
    if (!dept) return null;
    return MANAGERS.find(m => m.depts.some(d => dept.toLowerCase().includes(d.toLowerCase())));
}
function genRefNumber() {
    const d = new Date();
    const ymd = d.getFullYear().toString() + String(d.getMonth()+1).padStart(2,'0') + String(d.getDate()).padStart(2,'0');
    const seq = String(Math.floor(Math.random()*9000)+1000);
    return `GIS-${ymd}-${seq}`;
}

