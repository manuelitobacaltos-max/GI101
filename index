                        <small>Vienovo Philippines &middot; Material Request System</small>
                    </div>
                    <div class="text-end">
                        <div class="ref-badge" id="refNumber">GIS-LOADING...</div>
                        <small class="d-block mt-1" id="dateNow"></small>
                    </div>
                </div>

                <div class="p-4 p-md-5">
                    <!-- WORKFLOW STRIP -->
                    <div class="workflow-strip">
                        <div class="workflow-step active" id="wf-1">
                            <div class="step-num">1</div>
                            <div><strong>Draft</strong><br>Requestor fills form</div>
                        </div>
                        <div class="workflow-step" id="wf-2">
                            <div class="step-num">2</div>
                            <div><strong>Approval</strong><br>Manager review</div>
                        </div>
                        <div class="workflow-step" id="wf-3">
                            <div class="step-num">3</div>
                            <div><strong>Issuance</strong><br>Warehouse</div>
                        </div>
                        <div class="workflow-step" id="wf-4">
                            <div class="step-num">4</div>
                            <div><strong>Completed</strong><br>Logged in SAP</div>
                        </div>
                    </div>

                    <form id="gisForm">
                        <!-- REQUESTOR -->
                        <div class="mb-4">
                            <label class="section-title"><i class="bi bi-person-badge"></i> Requestor Information</label>
                            <div class="row g-2">
                                <div class="col-md-7">
                                    <label class="form-label small mb-1">Employee Name</label>
                                    <select id="employeeList" class="form-select" required>
