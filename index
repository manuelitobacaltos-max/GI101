                                </div>
                                <div class="col-md-3 mt-2">
                                    <label class="form-label small mb-1">Date Needed</label>
                                    <input type="date" id="dateNeeded" class="form-control" required>
                                </div>
                            </div>
                        </div>

                        <!-- ITEMS -->
                        <div class="mb-4">
                            <label class="section-title"><i class="bi bi-list-check"></i> Items Requested</label>
                            <div class="table-responsive">
                                <table class="table table-bordered items-table align-middle" id="itemsTable">
                                    <thead>
                                        <tr>
